{
  "build": {
    "context": "..",
    "dockerfile": "Dockerfile"
  },
  "postCreateCommand": "scripts/setup",
  "mounts": [
    "source=${localEnv:HOME}/.kube,target=/home/vscode/.kube,type=bind"
  ],
  "remoteEnv": {
    "KUBECONFIG": "/home/vscode/.kube/config"
  },
  "forwardPorts": [
    8080
  ]
}
